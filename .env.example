# Resend (https://resend.com) — required for contact form emails
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender on your Resend domain, e.g. Neighbors Pest <contact@neighborspestsolutions.com>
RESEND_FROM_EMAIL=Neighbors Pest Solutions <contact@neighborspestsolutions.com>
# Where quote requests are delivered
CONTACT_RECIPIENT_EMAIL=info@neighborspestsolutions.com
